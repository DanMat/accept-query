{
  "name": "@danmat/accept-query",
  "version": "0.1.2",
  "description": "Parse, build, and content-negotiate the Accept-Query HTTP header (RFC 10008) for the QUERY method. Zero dependencies, fully typed.",
  "keywords": [
    "accept-query",
    "http",
    "query",
    "query-method",
    "rfc10008",
    "rfc-10008",
    "content-negotiation",
    "media-type",
    "q-value",
    "header"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky"
  },
  "author": "Dan Matthew <dannymatthew@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanMat/accept-query.git"
  },
  "bugs": {
    "url": "https://github.com/DanMat/accept-query/issues"
  },
  "homepage": "https://github.com/DanMat/accept-query#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc,md}": "biome check --write --no-errors-on-unmatched"
  }
}
